{
  "description": "Inject personal principles at session start and preserve through compaction",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [{
          "type": "command",
          "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/read-ethos.sh",
          "timeout": 5
        }]
      }
    ],
    "PreCompact": [
      {
        "hooks": [{
          "type": "command",
          "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/read-ethos.sh",
          "timeout": 5
        }]
      }
    ]
  }
}
