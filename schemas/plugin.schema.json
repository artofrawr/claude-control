{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "Plugin Metadata",
  "description": "Schema for plugin.json files in bazaar plugins.",
  "type": "object",
  "required": ["name", "description", "version"],
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$",
      "description": "Plugin name in lowercase kebab-case, must match directory name."
    },
    "description": {
      "type": "string",
      "description": "One-line description of the plugin."
    },
    "version": {
      "type": "string",
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)$",
      "description": "Semantic version (e.g., 1.0.0)."
    },
    "author": {
      "type": "string",
      "description": "Plugin author name or handle."
    },
    "keywords": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Keywords for discoverability."
    },
    "license": {
      "type": "string",
      "description": "SPDX license identifier (e.g., MIT, Apache-2.0)."
    },
    "homepage": {
      "type": "string",
      "format": "uri",
      "description": "URL to the plugin's homepage or documentation."
    },
    "repository": {
      "type": "string",
      "format": "uri",
      "description": "URL to the plugin's source repository."
    }
  },
  "additionalProperties": false
}
